# am-i-blocked environment configuration
# Copy this file to .env and fill in your values.
# Lines starting with # are comments.

# ---------------------------------------------------------------------------
# Infrastructure
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql+psycopg://app:app@postgres:5432/amiblockeddb
REDIS_URL=redis://redis:6379/0

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
# Header injected by your reverse proxy (e.g. nginx, Cloudflare Access) that
# carries the authenticated username of the requester.
APP_IDENTITY_HEADER=X-Forwarded-User
ANONYMOUS_USER=anonymous

# ---------------------------------------------------------------------------
# Feature flags
# ---------------------------------------------------------------------------
ENABLE_BOUNDED_PROBES=true

# ---------------------------------------------------------------------------
# PAN-OS on-prem firewalls
# Comma-separated list of management-plane hostnames or IPs.
# ---------------------------------------------------------------------------
PANOS_FW_HOSTS=
PANOS_API_KEY=
PANOS_VERIFY_SSL=true
PANOS_MAX_CONCURRENT=2

# ---------------------------------------------------------------------------
# Strata Cloud Manager / Prisma Access
# ---------------------------------------------------------------------------
SCM_CLIENT_ID=
SCM_CLIENT_SECRET=
SCM_TSG_ID=
# SCM_AUTH_URL=https://auth.apps.paloaltonetworks.com/oauth2/access_token
# SCM_API_BASE_URL=https://api.sase.paloaltonetworks.com

# ---------------------------------------------------------------------------
# SD-WAN OpsCenter
# ---------------------------------------------------------------------------
SDWAN_API_URL=
SDWAN_API_KEY=
SDWAN_VERIFY_SSL=true

# ---------------------------------------------------------------------------
# CrowdStrike Falcon LogScale
# ---------------------------------------------------------------------------
LOGSCALE_URL=
LOGSCALE_REPO=
LOGSCALE_TOKEN=

# ---------------------------------------------------------------------------
# Torq (outbound only)
# ---------------------------------------------------------------------------
TORQ_CLIENT_ID=
TORQ_CLIENT_SECRET=
# TORQ_API_BASE_URL=https://api.torq.io

# ---------------------------------------------------------------------------
# Worker settings
# ---------------------------------------------------------------------------
WORKER_CONCURRENCY=4
JOB_TIMEOUT_S=120

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
# LOG_LEVEL: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
# LOG_FORMAT: json | console
LOG_FORMAT=json
